# ============================================================
# 飞书凭证（飞书开放平台 → 应用管理 → 凭证与基础信息）
# ============================================================

# 飞书应用 ID，格式：cli_xxxxxxxxxx
CTF_FEISHU_APP_ID=cli_xxxxxxxxxx

# 飞书应用 Secret
CTF_FEISHU_APP_SECRET=xxxxxxxx

# 飞书 API 域名。国内版固定填此值；海外版改为 https://open.larksuite.com
CTF_FEISHU_DOMAIN=https://open.feishu.cn

# ============================================================
# 访问控制
# ============================================================

# 允许使用的飞书用户 open_id，多个用分号分隔
# 在飞书开放平台「用户信息」或通过 /me 接口获取 open_id
CTF_ALLOWED_USERS=ou_xxxxxxxx

# 允许 Claude 操作的本地目录白名单，多个用分号分隔
# Linux/macOS 示例：/home/user/projects/project-a;/home/user/projects/project-b
# Windows 示例：D:\work\project-a;D:\work\project-b
CTF_ALLOWED_DIRS=/home/user/projects/project-a;/home/user/projects/project-b

# 目录别名映射，格式：别名=路径，多个用分号分隔
# 用于在飞书消息中用短名称引用目录，避免填写完整路径
# Linux/macOS 示例：project-a=/home/user/projects/project-a;project-b=/home/user/projects/project-b
# Windows 示例：project-a=D:\work\project-a;project-b=D:\work\project-b
CTF_DIR_ALIASES=project-a=/home/user/projects/project-a;project-b=/home/user/projects/project-b

# ============================================================
# Claude 配置
# ============================================================

# 默认使用的 Claude 模型，支持：opus、sonnet、haiku 等
# 默认值：sonnet
CTF_DEFAULT_MODEL=sonnet

# 默认启动模式，支持：code（代码模式）、chat（对话模式）
# 默认值：code
CTF_DEFAULT_MODE=code

# ============================================================
# 进程管理
# ============================================================

# 日志级别，支持：debug、info、warn、error
# 默认值：info
CTF_LOG_LEVEL=info

# 工具权限白名单：列出的工具无需用户授权直接放行，多个用分号分隔
# 支持精确工具名和带参数通配模式，例如：Read;Glob;Bash(npm *);Bash(git *)
# 默认值：空（所有工具都需要授权）
CTF_PERMISSION_ALLOW_LIST=

# 最大并发查询数，超出时新请求排队等待
# 默认值：3
CTF_MAX_CONCURRENT_QUERIES=3

# 单次查询超时时间（毫秒）
# 默认值：600000（10 分钟）
CTF_QUERY_TIMEOUT_MS=600000

# 健康检查 HTTP 端口，0 表示不启动健康检查服务
# 默认值：0
CTF_HEALTH_PORT=0

# 入站限流：每个用户每分钟最多发送的消息数，0 表示不限流
# 默认值：20
CTF_INBOUND_RATE_LIMIT=20
